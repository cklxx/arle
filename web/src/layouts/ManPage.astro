---
import "../styles/tokens.css";
import "../styles/global.css";
import type { Locale } from "../data/content.ts";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang={locale.lang}>
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{locale.meta.title}</title>
<meta name="description" content={locale.meta.description} />
<meta name="color-scheme" content="light" />
<meta property="og:title" content={locale.meta.ogTitle} />
<meta property="og:description" content={locale.meta.ogDescription} />
<meta property="og:type" content="website" />
<meta property="og:url" content={locale.meta.ogUrl} />
<link rel="canonical" href={locale.meta.canonical} />
<link rel="alternate" hreflang="en" href="https://cklxx.github.io/arle/" />
<link rel="alternate" hreflang="zh-Hans" href="https://cklxx.github.io/arle/zh-cn/" />
<link rel="icon" href={`${base}favicon.svg`} />
</head>
<body>
<main class="page">
  <slot />
</main>
</body>
</html>
