---
import Site from "../layouts/Site.astro";
import Masthead from "../components/Masthead.astro";
import Hero from "../components/home/Hero.astro";
import Section from "../components/home/Section.astro";
import Install from "../components/home/Install.astro";
import Bench from "../components/home/Bench.astro";
import Matrix from "../components/home/Matrix.astro";
import Files from "../components/home/Files.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { ZH } from "../data/content.ts";

const s = ZH.sections;
---
<Site locale={ZH}>
  <div class="page">
    <Masthead left={ZH.masthead.left} links={ZH.masthead.links} />
    <Hero hero={ZH.hero} />

    <Section id="install" title={s.install.title} caption={s.install.caption}>
      <Install cards={s.install.cards} />
    </Section>

    <Section id="bench" title={s.bench.title} caption={s.bench.caption}>
      <Bench rows={s.bench.rows} snapshotLabel="完整快照 ↗" />
    </Section>

    <Section id="matrix" title={s.matrix.title} caption={s.matrix.caption}>
      <Matrix head={s.matrix.head} rows={s.matrix.rows} />
    </Section>

    <Section id="files" title={s.files.title} caption={s.files.caption}>
      <Files rows={s.files.rows} />
    </Section>

    <SiteFooter left={ZH.footer.left} right={ZH.footer.right} />
  </div>
</Site>

<style>
  .page {
    max-width: 920px;
    margin: 0 auto;
    padding: 56px 36px 72px;
    counter-reset: section;
  }
  @media (max-width: 760px) {
    .page { padding: 40px 22px 56px; }
  }
</style>
