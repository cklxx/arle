---
interface Props {
  id: string;
  title: string;
}
const { id, title } = Astro.props;
---
<section id={id}>
  <h2>
    <span class="h2-num" aria-hidden="true"></span>
    <span class="h2-sect" aria-hidden="true">§</span>
    <span class="h2-title">{title}</span>
    <span class="h2-rule" aria-hidden="true"></span>
  </h2>
  <slot />
</section>
