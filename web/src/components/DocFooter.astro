---
import type { FooterCol } from "../data/content.ts";
interface Props {
  cols: FooterCol[];
  meta: string; // raw HTML
}
const { cols, meta } = Astro.props;
---
<section class="docfoot" aria-label="documentation navigation">
  {cols.map((col) => (
    <div class="docfoot-col">
      <h4>{col.heading}</h4>
      <ul>
        {col.links.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </div>
  ))}
  <div class="docfoot-meta">
    <span set:html={meta} />
    <span><a href="https://github.com/cklxx/arle">cklxx/arle</a></span>
  </div>
</section>
