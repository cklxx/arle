---
interface Props {
  left: string;
  right: { label: string; href: string };
}
const { left, right } = Astro.props;
---
<footer>
  <span>{left}</span>
  <span><a href={right.href}>{right.label}</a></span>
</footer>
<style>
  footer {
    margin-top: 96px;
    padding-top: 22px;
    border-top: 1px solid var(--ink);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px 24px;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-dim);
  }
  footer a {
    color: inherit;
    text-decoration: none;
    transition: color var(--t-base);
  }
  footer a:hover { color: var(--ink); }
</style>
