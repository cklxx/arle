---
interface Seg {
  label: string; // raw HTML allowed
  href: string;
  cls?: string;
}
interface Props {
  segments: Seg[];
  ariaLabel?: string;
}
const { segments, ariaLabel = "Quick links" } = Astro.props;
---
<nav class="statusline" aria-label={ariaLabel}>
  {segments.map((s, i) => (
    <>
      <a class={`sl-seg ${s.cls ?? ""}`.trim()} href={s.href} set:html={s.label} />
      {i === 2 && <span class="sl-seg sl-spacer" aria-hidden="true"></span>}
    </>
  ))}
</nav>
