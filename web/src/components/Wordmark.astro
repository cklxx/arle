---
interface Props {
  width?: number;
  height?: number;
  ariaLabel?: string;
}
const { width = 80, height = 24, ariaLabel = "ARLE" } = Astro.props;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 80 24"
  width={width}
  height={height}
  role="img"
  aria-label={ariaLabel}
>
  <text
    x="0"
    y="18"
    font-family="ui-monospace, SFMono-Regular, Menlo, monospace"
    font-size="18"
    font-weight="700"
    fill="currentColor"
    letter-spacing="2"
  >ARLE</text>
  <text
    x="58"
    y="18"
    font-family="ui-monospace, SFMono-Regular, Menlo, monospace"
    font-size="14"
    fill="#087A73"
  >$</text>
</svg>
