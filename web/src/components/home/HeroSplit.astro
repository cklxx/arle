---
import type { Locale } from "../../data/content.ts";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const base = import.meta.env.BASE_URL;

const display = locale.hero.display;
const stats = locale.hero.stats ?? [];
const installLabel = locale.hero.installLabel ?? "install";
const heroInstall = locale.sections.install.cards[0];
const heroInstallSecondary = locale.sections.install.cards[1];

// Compose the hero install block: brew block + curl block (single <pre>).
const installLines = [
  ...heroInstall.lines,
  '<span class="c"># or — one-liner curl installer</span>',
  ...(heroInstallSecondary?.lines ?? []),
].join("\n");
---
<section class="hero" aria-label="banner">
  <div class="hero-l">
    <div>
      <p class="hero-kicker reveal">
        <span class="dot" aria-hidden="true"></span>
        {display ? display.status : locale.hero.kicker}
      </p>
      {display ? (
        <h1 class="hero-h1 reveal">
          {display.h1Lines.map((line, i) => (
            <Fragment>
              <span set:html={line} />
              {i < display.h1Lines.length - 1 && <br />}
            </Fragment>
          ))}
        </h1>
      ) : (
        <h1 class="sr-only">{locale.meta.title}</h1>
      )}
      {display?.replPrimary && (
        <p class="repl-line reveal">
          {display.replPrimary}
          {display.replSuffix && <span class="dim"> {display.replSuffix}</span>}
        </p>
      )}
      <p class="hero-lede reveal" set:html={display ? display.lede : locale.hero.tagline} />
      <div class="hero-cta reveal">
        <a class="btn btn-primary" href="#install">
          $ {locale.hero.primaryCta}
          <span class="ar" aria-hidden="true">&rarr;</span>
        </a>
        <a class="btn btn-ghost" href={`${base}docs/`}>
          {locale.lang === "zh-Hans" ? "阅读文档" : "Read the docs"}
          <span class="ar" aria-hidden="true">&#x2197;</span>
        </a>
      </div>
    </div>
    <div class="hero-signals reveal" aria-label="status chips">
      {locale.hero.signals.map((s) => (
        <span class={`sig sig-${s.status}`}>
          <span set:html={s.kv} />
        </span>
      ))}
    </div>
  </div>

  <div class="hero-r">
    <div class="reveal">
      <div class="install-label">
        <span>{installLabel}</span>
        <button class="copy" type="button" data-copy aria-label="copy install commands">copy</button>
      </div>
      <pre class="install-pre" set:html={installLines}></pre>
    </div>

    {stats.length > 0 && (
      <div class="perf reveal" aria-label="benchmark snapshot">
        {stats.map((s) => (
          <div class="stat">
            <span class="lbl">{s.lbl}</span>
            <span class="num">{s.num}<span class="u">{s.unit}</span></span>
            <span class="meta">
              <span set:html={s.meta}></span>
              {s.spark && (
                <svg class="spark" viewBox="0 0 60 14" aria-hidden="true">
                  <path d={s.spark} />
                </svg>
              )}
            </span>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
<style>
  .hero {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    min-height: 760px;
    border-bottom: 1px solid var(--line);
    position: relative;
    overflow: hidden;
  }
  /* Engineering-drawing baseline that crosses both panes. */
  .hero::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 56%;
    height: 1px;
    background: var(--line);
    z-index: 0;
    pointer-events: none;
  }
  /* Repeating tick marks on that baseline. */
  .hero::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: calc(56% - 4px);
    height: 9px;
    pointer-events: none;
    z-index: 0;
    background-image: linear-gradient(to right, var(--line) 1px, transparent 1px);
    background-size: 80px 100%;
    opacity: 0.5;
  }
  .hero-l, .hero-r { position: relative; z-index: 1; }
  .hero-l {
    padding: 88px 64px 56px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 32px;
    min-width: 0;
  }
  .hero-r {
    background: var(--ink);
    color: var(--paper);
    padding: 88px 56px 56px;
    border-left: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 28px;
    min-width: 0;
  }

  .hero-kicker {
    color: var(--ink-dim);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin: 0 0 28px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .hero-kicker .dot {
    width: 6px;
    height: 6px;
    background: var(--ok);
    border-radius: 50%;
    box-shadow: 0 0 0 3px rgba(22, 163, 74, 0.15);
    flex: none;
  }

  .hero-h1 {
    font-size: clamp(52px, 6.6vw, 96px);
    line-height: 0.95;
    letter-spacing: -0.045em;
    margin: 0 0 18px;
    font-weight: 700;
    max-width: none;
    white-space: nowrap;
    color: var(--ink);
  }
  @media (max-width: 1280px) {
    .hero-h1 { white-space: normal; }
  }

  /* Knife-through highlight strip — crosses the letterforms via mix-blend. */
  .hero-h1 :global(.strike) {
    display: inline-block;
    position: relative;
    padding: 0 0.04em;
  }
  .hero-h1 :global(.strike::before) {
    content: "";
    position: absolute;
    left: -0.02em;
    right: -0.02em;
    top: 0.40em;
    height: 0.20em;
    background: var(--hl);
    z-index: 1;
    transform: skewY(-2deg);
  }
  .hero-h1 :global(.strike .txt) {
    position: relative;
    z-index: 2;
    mix-blend-mode: multiply;
  }
  .hero-h1 :global(em) {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    color: var(--ink-blue);
    letter-spacing: -0.02em;
  }

  /* Repl annotation — what we replace, in ink-blue with a 24px hairline. */
  .repl-line {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--ink-blue);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0 0 32px;
    flex-wrap: wrap;
  }
  .repl-line::before {
    content: "";
    width: 24px;
    height: 1px;
    background: var(--ink-blue);
    flex: none;
  }
  .repl-line .dim {
    color: var(--ink-dim);
    text-transform: none;
    letter-spacing: 0;
    font-family: var(--serif);
    font-style: italic;
    font-size: 13px;
  }

  .hero-lede {
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 46ch;
    margin: 0 0 36px;
  }
  .hero-lede :global(b) { color: var(--ink); font-weight: 700; }
  .hero-lede :global(code) {
    background: var(--paper-dim);
    border: 1px solid var(--line);
    padding: 0 6px;
    font-weight: 500;
    color: var(--ink);
  }
  .hero-lede :global(a.inline) {
    color: var(--ink-blue);
    text-decoration-color: var(--ink-blue);
  }

  .hero-cta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }

  .hero-signals {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px 28px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
    max-width: 520px;
  }
  .sig {
    display: flex;
    align-items: baseline;
    gap: 10px;
    font-size: 12px;
    color: var(--ink-dim);
    line-height: 1.5;
  }
  .sig::before {
    content: "";
    width: 6px;
    height: 6px;
    background: var(--ok);
    border-radius: 50%;
    flex: none;
    transform: translateY(-1px);
  }
  .sig.sig-warn::before { background: var(--warn); }
  .sig.sig-blue::before { background: var(--ink-blue); }
  .sig :global(code) { color: var(--ink); font-weight: 500; }

  /* hero-right install + perf */
  .install-label {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin: 0 0 12px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }
  .install-label .copy {
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
    padding: 3px 10px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: transparent;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: none;
    transition: all 150ms ease;
  }
  .install-label .copy:hover {
    background: rgba(255, 255, 255, 0.08);
    color: var(--paper);
  }
  .install-label .copy.done {
    color: #6EE7A1;
    border-color: #6EE7A1;
  }
  .install-pre {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: var(--paper);
    margin: 0;
    padding: 18px 22px;
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.7;
    white-space: pre-wrap;
    word-break: break-all;
    overflow-x: auto;
  }
  .install-pre :global(.p) { color: rgba(255, 255, 255, 0.4); user-select: none; }
  .install-pre :global(.c) { color: rgba(255, 255, 255, 0.5); }

  .perf {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.12);
    margin-top: auto;
  }
  .stat {
    background: var(--ink);
    padding: 22px 22px 16px;
    min-height: 140px;
    display: flex;
    flex-direction: column;
  }
  .stat .lbl {
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 12px;
  }
  .stat .num {
    font-size: 44px;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--paper);
    font-feature-settings: "tnum" 1;
  }
  .stat .num .u {
    font-size: 13px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.55);
    margin-left: 5px;
    letter-spacing: 0;
  }
  .stat .meta {
    margin-top: 14px;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.5);
    display: flex;
    align-items: center;
    gap: 10px;
    justify-content: space-between;
  }
  .stat .meta :global(b) { color: var(--paper); font-weight: 500; }
  .stat .spark {
    width: 60px;
    height: 14px;
    flex: none;
  }
  .stat .spark path {
    stroke: rgba(255, 255, 255, 0.55);
    stroke-width: 1.2;
    fill: none;
  }

  @media (max-width: 1100px) {
    .hero { grid-template-columns: 1fr; min-height: 0; }
    .hero::before, .hero::after { display: none; }
    .hero-r {
      border-left: none;
      border-top: 1px solid var(--line);
    }
    .hero-l, .hero-r { padding: 64px 32px; }
  }
  @media (max-width: 640px) {
    .hero-l, .hero-r { padding: 48px 20px; }
    .perf { grid-template-columns: 1fr; }
    .hero-signals { grid-template-columns: 1fr; }
  }
</style>
