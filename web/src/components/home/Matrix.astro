---
import type { Matrix } from "../../data/content.ts";

interface Props {
  matrix: Matrix;
}
const { matrix } = Astro.props;
---
<div class="matrix-wrap">
  <table class="mtx">
    <thead>
      <tr>{matrix.head.map((h) => <th>{h}</th>)}</tr>
    </thead>
    <tbody>
      {matrix.rows.map((row) => (
        <tr>
          {row.map((cell, idx) => (
            <td class={idx === 0 ? "k" : ""} set:html={cell} />
          ))}
        </tr>
      ))}
    </tbody>
  </table>
</div>
<p class="matrix-note" set:html={matrix.note} />
<style>
  .matrix-wrap {
    border: 1px solid var(--line);
    background: var(--paper);
    overflow-x: auto;
  }
  .mtx { width: 100%; border-collapse: collapse; font-size: 13px; }
  .mtx thead th {
    padding: 16px 20px;
    text-align: left;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-dim);
    border-bottom: 1px solid var(--line);
    font-weight: 500;
    background: var(--paper-dim);
    white-space: nowrap;
  }
  .mtx tbody td {
    padding: 18px 20px;
    border-bottom: 1px solid var(--line-soft);
    vertical-align: middle;
    color: var(--ink-soft);
  }
  .mtx tbody tr:last-child td { border-bottom: none; }
  .mtx tbody td.k { color: var(--ink); font-weight: 600; white-space: nowrap; }
  .mtx :global(code) {
    background: var(--paper-dim);
    border: 1px solid var(--line);
    padding: 2px 8px;
    font-weight: 500;
  }
  /* Map the legacy m-ok/m-warn/m-dim classes (already in content data)
     onto the new pill design so existing data needs no rewrite. */
  .mtx :global(.m-ok),
  .mtx :global(.m-warn),
  .mtx :global(.m-dim) {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 500;
    padding: 4px 10px;
    border: 1px solid var(--line);
    background: transparent;
  }
  .mtx :global(.m-ok::before),
  .mtx :global(.m-warn::before),
  .mtx :global(.m-dim::before) {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
  }
  .mtx :global(.m-ok)   { color: var(--ok);   border-color: var(--ok); }
  .mtx :global(.m-warn) { color: var(--warn); border-color: var(--warn); }
  .mtx :global(.m-dim)  { color: var(--ink-dim); border-color: var(--line); }

  .matrix-note {
    margin: 24px 0 0;
    font-size: 13px;
    color: var(--ink-dim);
    line-height: 1.65;
  }
  .matrix-note :global(a) { color: var(--ink); text-decoration-color: var(--line); }
</style>
