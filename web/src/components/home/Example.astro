---
interface Props {
  title: string;
  /** Side-pane prose paragraph (raw HTML). */
  body: string;
  /** Pre-formatted lines (HTML allowed). */
  lines: string[];
  /** Optional secondary CTA shown under prose. */
  docsHref?: string;
  docsLabel?: string;
}
const { title, body, lines, docsHref, docsLabel } = Astro.props;
---
<div class="example">
  <div class="example-side">
    <h3>{title}</h3>
    <p set:html={body} />
    {docsHref && docsLabel && (
      <p class="cta">
        <a class="ghost" href={docsHref}>{docsLabel} <span aria-hidden="true">&#x2197;</span></a>
      </p>
    )}
  </div>
  <pre set:html={lines.join("\n")}></pre>
</div>
<style>
  .example {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 64px;
    align-items: start;
  }
  .example-side h3 {
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin: 0 0 14px;
    font-family: var(--mono);
    text-transform: none;
  }
  .example-side p {
    font-family: var(--serif);
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.6;
    margin: 0 0 16px;
  }
  .example-side :global(code) {
    font-family: var(--mono);
    background: var(--paper-warm);
    border: 1px solid var(--line);
    padding: 1px 6px;
    font-weight: 500;
    color: var(--ink);
    font-size: 12px;
  }
  .example-side .ghost {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: 1px solid var(--line);
    padding: 8px 12px;
    color: var(--ink);
    text-decoration: none;
    font-size: 11px;
    transition: border-color 100ms ease;
  }
  .example-side .ghost:hover { border-color: var(--ink); }

  .example pre {
    background: var(--ink);
    color: var(--paper);
    border: none;
    padding: 36px 36px 36px 56px;
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.7;
    overflow-x: auto;
    white-space: pre;
    margin: 0;
    position: relative;
  }
  /* 32px line-number gutter — engineering-tool feel. */
  .example pre::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 32px;
    background: rgba(255, 255, 255, 0.04);
    border-right: 1px solid rgba(255, 255, 255, 0.08);
  }
  .example pre :global(.p) { color: rgba(255,255,255,0.45); user-select: none; }
  .example pre :global(.c) { color: rgba(255,255,255,0.45); }
  .example pre :global(i)  { color: rgba(255,255,255,0.7); font-style: normal; }
  .example pre :global(b)  { color: var(--paper); }
  .example pre :global(.k) { color: var(--hl); }
  .example pre :global(.ln) {
    display: inline-block;
    width: 2.5ch;
    margin-right: 0.6ch;
    padding-right: 0.4ch;
    text-align: right;
    color: rgba(255,255,255,0.4);
    user-select: none;
  }

  @media (max-width: 1100px) {
    .example { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
