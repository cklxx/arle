---
import type { BenchRow } from "../../data/content.ts";

interface Props {
  rows: BenchRow[];
  isZh?: boolean;
}
const { rows, isZh = false } = Astro.props;
const fullSnapshotLabel = isZh ? "完整快照" : "Full snapshot";
const runCmdLabel = isZh ? "运行命令：" : "Run cmd:";
---
<div class="perf-detail">
  {rows.map((r) => {
    const stab = r.stability ?? "stable";
    const stabClass = stab === "stable" ? "ok" : "warn";
    const grid = r.grid ?? [];
    return (
      <article class="perf-card">
        <div class="perf-card-h">
          <span class="b">{r.backend}</span>
          <span class="d">{r.date}</span>
          <span class="meta">{r.hardware} · {r.model}</span>
          <span class={`s s-${stabClass}`}>{stab}</span>
        </div>
        {grid.length > 0 && (
          <div class="perf-card-body">
            {grid.map((g) => (
              <div>
                <div class="l">{g.label}</div>
                <div class="v">{g.value}<span class="u">{g.unit}</span></div>
              </div>
            ))}
          </div>
        )}
        <div class="perf-card-foot">
          {r.cmd ? (
            <span>{runCmdLabel} <code>{r.cmd}</code></span>
          ) : (
            <span set:html={r.metric} />
          )}
          <a href={r.href}>{fullSnapshotLabel} <span aria-hidden="true">&#x2197;</span></a>
        </div>
      </article>
    );
  })}
</div>
<style>
  .perf-detail {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .perf-card { border: 1px solid var(--line); padding: 0; background: var(--paper); }
  .perf-card-h {
    padding: 16px 24px;
    border-bottom: 1px solid var(--line);
    display: flex;
    gap: 16px;
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-dim);
    align-items: center;
    flex-wrap: wrap;
  }
  .perf-card-h .b {
    color: var(--ink);
    padding: 1px 6px;
    border: 1px solid var(--line);
    background: var(--paper-dim);
  }
  .perf-card-h .d { color: var(--ink); }
  .perf-card-h .meta { color: var(--ink-soft); }
  .perf-card-h .s {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .perf-card-h .s::before {
    content: "";
    width: 6px; height: 6px;
    background: currentColor;
    border-radius: 50%;
  }
  .perf-card-h .s.s-ok   { color: var(--ok); }
  .perf-card-h .s.s-warn { color: var(--warn); }

  .perf-card-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--line);
  }
  .perf-card-body > div {
    background: var(--paper);
    padding: 24px;
  }
  .perf-card-body .l {
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-dim);
    margin-bottom: 8px;
  }
  .perf-card-body .v {
    font-size: 36px;
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--ink);
  }
  .perf-card-body .v .u {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-dim);
    margin-left: 4px;
  }
  .perf-card-foot {
    padding: 16px 24px;
    border-top: 1px solid var(--line);
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--ink-dim);
    background: var(--paper-dim);
    gap: 12px;
    flex-wrap: wrap;
  }
  .perf-card-foot a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px dotted var(--line);
  }
  .perf-card-foot a:hover { border-bottom-color: var(--ink); }

  @media (max-width: 1100px) {
    .perf-detail { grid-template-columns: 1fr; }
  }
</style>
