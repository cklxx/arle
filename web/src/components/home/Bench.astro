---
import type { BenchRow } from "../../data/content.ts";

interface Props {
  rows: BenchRow[];
  /** Localised label for the right-hand snapshot link. */
  snapshotLabel?: string;
}
const { rows, snapshotLabel = "snapshot ↗" } = Astro.props;

const tagClass = (s: BenchRow["stability"]) =>
  s === "stable" ? "ok" : s === "beta" ? "warn" : "dim";
---
<div class="bench">
  {rows.map((r) => (
    <div class="card">
      <div class="h">
        <span class="date">{r.date}</span>
        <span class={`tag ${tagClass(r.stability)}`}>{r.stabilityLabel}</span>
      </div>
      <p class="ttl" set:html={r.caption} />
      <div class="grid">
        {r.cells.map((c) => (
          <div class="cell">
            <div class="key">{c.key}</div>
            <div class="val">{c.value}<span class="u">{c.unit}</span></div>
          </div>
        ))}
      </div>
      <div class="foot">
        <span><code>{r.cmd}</code></span>
        <a href={r.href}>{snapshotLabel}</a>
      </div>
    </div>
  ))}
</div>
<style>
  .bench {
    display: grid;
    gap: 20px;
    grid-template-columns: 1fr 1fr;
  }
  .card {
    border: 1px solid var(--line);
    padding: 22px 24px;
    background: var(--paper);
  }
  .h {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 14px;
    align-items: baseline;
    font-size: 11px;
    color: var(--ink-soft);
    margin-bottom: 14px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--line-soft);
  }
  .h .date {
    color: var(--ink);
    font-weight: 700;
    font-feature-settings: "tnum" 1;
  }
  .h .tag {
    margin-left: auto;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 2px 7px;
    border: 1px solid currentColor;
    white-space: nowrap;
  }
  .h .tag.ok { color: var(--ok); border-color: rgba(22,163,74,0.4); }
  .h .tag.warn { color: var(--warn); border-color: rgba(217,119,6,0.4); }
  .h .tag.dim { color: var(--ink-dim); border-color: var(--line); }

  .ttl {
    font-size: 12px;
    color: var(--ink-soft);
    margin: 0 0 18px;
  }
  .ttl :global(b) { color: var(--ink); font-weight: 600; }
  .ttl :global(code) { color: var(--ink); }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px 20px;
    margin-bottom: 18px;
  }
  .cell .key {
    font-size: 9px;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: var(--ink-dim);
    margin-bottom: 4px;
  }
  .cell .val {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    font-feature-settings: "tnum" 1;
    color: var(--ink);
  }
  .cell .val .u {
    font-size: 11px;
    font-weight: 500;
    color: var(--ink-dim);
    margin-left: 4px;
    letter-spacing: 0;
  }

  .foot {
    font-size: 11px;
    color: var(--ink-soft);
    border-top: 1px solid var(--line-soft);
    padding-top: 12px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }
  .foot a { font-size: 11px; }
  .foot code { color: var(--ink); }

  @media (max-width: 760px) {
    .bench { grid-template-columns: 1fr; }
  }
</style>
