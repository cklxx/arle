---
interface Props {
  id: string;
  num: string;        // e.g. "01"
  label: string;      // small uppercase eyebrow (e.g. "Topology")
  heading: string;    // large display H2
}
const { id, num, label, heading } = Astro.props;
---
<section class="frame" id={id}>
  <div class="frame-head">
    <span class="label"><span class="num">{num}</span>{label}</span>
    <h2>{heading}</h2>
  </div>
  <slot />
</section>
