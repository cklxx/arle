---
import type { Locale } from "../../data/content.ts";

interface Props {
  locale: Locale;
  /** v3 — full-bleed heading rendered inside the warm-paper bleed instead of Frame's frame-head. */
  heading?: string;     // raw HTML (allows <em>)
  label?: string;
  num?: string;
}
const { locale, heading, label, num } = Astro.props;
const { topology } = locale.sections;
const isZh = locale.lang === "zh-Hans";

const colLabels = isZh
  ? ["FRONT DOOR", "RUNTIME SPINE", "KERNEL CRATES"]
  : ["FRONT DOOR", "RUNTIME SPINE", "KERNEL CRATES"];

const legendCells = isZh
  ? [
      { kind: "swatch",      label: "dispatch", body: "实线 · 进程内调用" },
      { kind: "swatch dash", label: "contract", body: "虚线 · HTTP / wire" },
      { kind: "dot ok",      label: "stable",   body: "<code>cuda-kernels</code> · <code>kv-native-sys</code>" },
      { kind: "dot warn",    label: "beta",     body: "<code>mlx-sys</code> · Apple Silicon" },
    ]
  : [
      { kind: "swatch",      label: "dispatch", body: "solid · in-process call" },
      { kind: "swatch dash", label: "contract", body: "dashed · HTTP / wire" },
      { kind: "dot ok",      label: "stable",   body: "<code>cuda-kernels</code> · <code>kv-native-sys</code>" },
      { kind: "dot warn",    label: "beta",     body: "<code>mlx-sys</code> · Apple Silicon" },
    ];
---
<div class="topo-bleed">
  {heading && (
    <div class="topo-head reveal">
      <span class="label"><span class="num">{num}</span>{label}</span>
      <h2 set:html={heading}></h2>
    </div>
  )}

  <div class="topo-grid">
    <div class="topo-side reveal">
      {topology.legend.map((leg) => (
        <p set:html={leg.body} />
      ))}
    </div>

    <div class="topo-stage reveal">
      <svg viewBox="0 0 800 380" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
        <defs>
          <pattern id="topo-dot" x="0" y="0" width="14" height="14" patternUnits="userSpaceOnUse">
            <circle cx="1" cy="1" r="0.6" fill="rgba(10,10,10,0.10)" />
          </pattern>
          <marker id="ah" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="9" markerHeight="9" orient="auto-start-reverse">
            <path d="M 0 0 L 10 5 L 0 10" fill="none" stroke="#0A0A0A" stroke-width="1.4" />
          </marker>
          <marker id="ah-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="9" markerHeight="9" orient="auto-start-reverse">
            <path d="M 0 0 L 10 5 L 0 10" fill="none" stroke="#1F2A44" stroke-width="1.4" />
          </marker>
        </defs>
        <rect width="800" height="380" fill="url(#topo-dot)" />

        <!-- column labels -->
        <text x="56"  y="34" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="2.5" fill="#737373">{colLabels[0]}</text>
        <text x="336" y="34" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="2.5" fill="#737373">{colLabels[1]}</text>
        <text x="616" y="34" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="2.5" fill="#737373">{colLabels[2]}</text>

        <line x1="40"  y1="46" x2="220" y2="46" stroke="#0A0A0A" stroke-width="1" />
        <line x1="320" y1="46" x2="500" y2="46" stroke="#0A0A0A" stroke-width="1" />
        <line x1="600" y1="46" x2="780" y2="46" stroke="#0A0A0A" stroke-width="1" />

        <!-- arle -->
        <rect x="40" y="80" width="200" height="240" fill="#FFFFFF" stroke="#0A0A0A" stroke-width="1.5" />
        <text x="56" y="110" font-family="JetBrains Mono, monospace" font-size="22" font-weight="700" fill="#0A0A0A">arle</text>
        <text x="56" y="126" font-family="JetBrains Mono, monospace" font-size="9"  letter-spacing="2" fill="#737373">UNIFIED CLI</text>
        <line x1="56" y1="140" x2="224" y2="140" stroke="#0A0A0A" stroke-width="1" stroke-dasharray="2 3" />
        <text x="56" y="166" font-family="JetBrains Mono, monospace" font-size="13" fill="#0A0A0A">→ run</text>
        <text x="56" y="194" font-family="JetBrains Mono, monospace" font-size="13" fill="#0A0A0A">→ serve</text>
        <text x="56" y="222" font-family="JetBrains Mono, monospace" font-size="13" fill="#0A0A0A">→ train</text>
        <text x="56" y="250" font-family="JetBrains Mono, monospace" font-size="13" fill="#0A0A0A">→ data</text>
        <text x="56" y="296" font-family="JetBrains Mono, monospace" font-size="11" fill="#737373">--doctor / --version</text>

        <!-- arle → infer (DISPATCH solid) -->
        <text x="248" y="190" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="1" fill="#737373">DISPATCH</text>
        <line x1="244" y1="204" x2="316" y2="204" stroke="#0A0A0A" stroke-width="1.5" marker-end="url(#ah)" />

        <!-- infer (ink-blue accent) -->
        <rect x="320" y="80" width="180" height="240" fill="#1F2A44" stroke="#1F2A44" stroke-width="1.5" />
        <text x="336" y="110" font-family="JetBrains Mono, monospace" font-size="22" font-weight="700" fill="#FFFFFF">infer</text>
        <text x="336" y="126" font-family="JetBrains Mono, monospace" font-size="9"  letter-spacing="2" fill="rgba(255,255,255,0.55)">RUNTIME SPINE</text>
        <line x1="336" y1="140" x2="484" y2="140" stroke="rgba(255,255,255,0.25)" stroke-width="1" stroke-dasharray="2 3" />
        <text x="336" y="166" font-family="JetBrains Mono, monospace" font-size="12" fill="#FFFFFF">scheduler</text>
        <text x="336" y="190" font-family="JetBrains Mono, monospace" font-size="12" fill="#FFFFFF">loader · ops</text>
        <text x="336" y="214" font-family="JetBrains Mono, monospace" font-size="12" fill="#FFFFFF">backend dispatch</text>
        <text x="336" y="238" font-family="JetBrains Mono, monospace" font-size="12" fill="#FFFFFF">/v1/* http</text>
        <text x="336" y="262" font-family="JetBrains Mono, monospace" font-size="12" fill="#FFFFFF">/metrics</text>
        <text x="336" y="296" font-family="JetBrains Mono, monospace" font-size="11" fill="rgba(255,255,255,0.6)">OpenAI v1 contract</text>

        <!-- infer → kernels (DISPATCH solid) -->
        <line x1="504" y1="140" x2="596" y2="118" stroke="#0A0A0A" stroke-width="1.5" marker-end="url(#ah)" />
        <line x1="504" y1="200" x2="596" y2="200" stroke="#0A0A0A" stroke-width="1.5" marker-end="url(#ah)" />
        <line x1="504" y1="260" x2="596" y2="282" stroke="#0A0A0A" stroke-width="1.5" marker-end="url(#ah)" />

        <!-- HTTP CONTRACT dashed arc back from infer's bottom edge -->
        <circle cx="410" cy="320" r="2.5" fill="#1F2A44" />
        <path d="M 410 322 Q 410 354 240 354 Q 100 354 100 322" stroke="#1F2A44" stroke-width="1.2" stroke-dasharray="3 4" fill="none" marker-end="url(#ah-blue)" />
        <text x="232" y="349" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="1.5" fill="#1F2A44">HTTP CONTRACT · /v1/*</text>

        <!-- kernels -->
        <rect x="600" y="84"  width="180" height="68" fill="#FFFFFF" stroke="#0A0A0A" stroke-width="1.5" />
        <text x="616" y="112" font-family="JetBrains Mono, monospace" font-size="14" font-weight="700" fill="#0A0A0A">cuda-kernels</text>
        <text x="616" y="132" font-family="JetBrains Mono, monospace" font-size="11" fill="#737373">CUDA + Triton AOT</text>
        <circle cx="762" cy="104" r="4" fill="#16A34A" />

        <rect x="600" y="166" width="180" height="68" fill="#FFFFFF" stroke="#0A0A0A" stroke-width="1.5" />
        <text x="616" y="194" font-family="JetBrains Mono, monospace" font-size="14" font-weight="700" fill="#0A0A0A">mlx-sys</text>
        <text x="616" y="214" font-family="JetBrains Mono, monospace" font-size="11" fill="#737373">Apple Silicon C++ bridge</text>
        <circle cx="762" cy="186" r="4" fill="#D97706" />

        <rect x="600" y="248" width="180" height="68" fill="#FFFFFF" stroke="#0A0A0A" stroke-width="1.5" />
        <text x="616" y="276" font-family="JetBrains Mono, monospace" font-size="14" font-weight="700" fill="#0A0A0A">kv-native-sys</text>
        <text x="616" y="296" font-family="JetBrains Mono, monospace" font-size="11" fill="#737373">local KV-tier substrate</text>
        <circle cx="762" cy="268" r="4" fill="#16A34A" />
      </svg>
      <div class="topo-legend">
        {legendCells.map((c) => (
          <div>
            <div class="row-1">
              {c.kind === "swatch" && <span class="swatch"></span>}
              {c.kind === "swatch dash" && <span class="swatch dash"></span>}
              {c.kind === "dot ok"   && <span class="dot ok"  aria-hidden="true">●</span>}
              {c.kind === "dot warn" && <span class="dot warn" aria-hidden="true">●</span>}
              <span>{c.label}</span>
            </div>
            <span set:html={c.body} />
          </div>
        ))}
      </div>
    </div>
  </div>
</div>
<style>
  .topo-bleed {
    background: var(--paper-warm);
    padding: 64px 64px 96px;
    position: relative;
    border-bottom: 1px solid var(--line);
  }
  .topo-head {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 64px;
    margin-bottom: 48px;
    align-items: end;
  }
  .topo-head .label {
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-dim);
  }
  .topo-head .label .num {
    color: var(--ink);
    margin-right: 8px;
    font-weight: 500;
  }
  .topo-head h2 {
    font-size: clamp(40px, 5.4vw, 80px);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1;
    margin: 0;
    max-width: 22ch;
    color: var(--ink);
    text-transform: none;
  }
  .topo-head h2 :global(em) {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    color: var(--ink-blue);
    letter-spacing: -0.02em;
  }
  .topo-grid {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 64px;
  }
  .topo-side p {
    font-family: var(--serif);
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.65;
    max-width: 30ch;
    margin: 0 0 16px;
  }
  .topo-side p:last-child { margin-bottom: 0; }
  .topo-side :global(b) { font-family: var(--mono); font-weight: 700; color: var(--ink); }
  .topo-side :global(code) {
    font-family: var(--mono);
    background: var(--paper);
    border: 1px solid var(--line);
    padding: 1px 6px;
    color: var(--ink);
    font-size: 12px;
  }

  .topo-stage {
    background: var(--paper);
    border: 1px solid var(--ink);
    position: relative;
  }
  .topo-stage svg {
    width: 100%;
    display: block;
    height: auto;
  }
  .topo-legend {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--ink);
  }
  .topo-legend > div {
    padding: 14px 18px;
    font-size: 12px;
    border-right: 1px solid var(--line);
    color: var(--ink-soft);
  }
  .topo-legend > div:last-child { border-right: none; }
  .topo-legend .row-1 {
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-dim);
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .topo-legend .swatch {
    display: inline-block;
    width: 12px;
    height: 2px;
    background: var(--ink);
  }
  .topo-legend .swatch.dash {
    background: none;
    border-top: 1px dashed var(--ink);
    height: 0;
    margin-top: 5px;
  }
  .topo-legend .dot {
    font-size: 12px;
    line-height: 1;
  }
  .topo-legend .dot.ok   { color: var(--ok); }
  .topo-legend .dot.warn { color: var(--warn); }
  .topo-legend :global(code) {
    font-family: var(--mono);
    color: var(--ink);
    font-weight: 600;
    font-size: 12px;
  }

  @media (max-width: 1100px) {
    .topo-bleed { padding: 48px 32px 64px; }
    .topo-head, .topo-grid { grid-template-columns: 1fr; gap: 32px; }
    .topo-side p { max-width: none; }
    .topo-legend { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .topo-bleed { padding: 40px 20px 48px; }
    .topo-legend { grid-template-columns: 1fr; }
    .topo-legend > div {
      border-right: none;
      border-bottom: 1px solid var(--line);
    }
    .topo-legend > div:last-child { border-bottom: none; }
  }
</style>
