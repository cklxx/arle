---
import type { Locale } from "../data/content.ts";
import HeroAscii from "./HeroAscii.astro";
import HeroSignals from "./HeroSignals.astro";
import HeroCta from "./HeroCta.astro";
import Section from "./Section.astro";
import Cmd from "./Cmd.astro";
import Jumps from "./Jumps.astro";
import DocFooter from "./DocFooter.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const s = locale.sections;
const heroInstall = s.install.cards[0];
---

<section class="hero" aria-label="banner">
  <h1 class="sr-only">{locale.meta.title}</h1>
  <p class="hero-kicker">{locale.hero.kicker}</p>
  <HeroAscii ariaLabel="ARLE — runtime-first Rust workspace" />
  <p class="hero-tagline" set:html={locale.hero.tagline} />
  <pre class="hero-install" aria-label="primary install line" set:html={heroInstall.lines.join("\n")}></pre>
  <div class="hero-row">
    <HeroCta
      primaryHref="#install"
      primaryLabel={locale.hero.primaryCta}
      secondaryHref="https://github.com/cklxx/arle"
      secondaryLabel={locale.hero.secondaryCta}
    />
    <HeroSignals signals={locale.hero.signals} ariaLabel="status chips" />
  </div>
  <Jumps items={locale.jumps} lang={locale.langSwitch} />
</section>

<Section id="name" title={s.name.title}>
  <p class="block" set:html={s.name.body} />
  <p class="note" set:html={s.name.note} />
</Section>

<Section id="install" title={s.install.title}>
  <p class="block" set:html={s.install.caption} />
  <div class="install-grid">
    {s.install.cards.map((c) => (
      <article class="mini-card install-card">
        <p class="install-label">{c.label}</p>
        <Cmd lines={c.lines} />
      </article>
    ))}
  </div>
  <p class="note" set:html={s.install.note} />
</Section>

<Section id="glance" title={s.glance.title}>
  <div class="glance-grid">
    {s.glance.cards.map((c) => (
      <article class="mini-card">
        <h3 set:html={`&mdash; ${c.h.replace(/^—\s*/, "")}`} />
        <p set:html={c.body} />
      </article>
    ))}
  </div>
</Section>

<Section id="topology" title={s.topology.title}>
  <ol class="topo">
    {s.topology.legend.map((l, i) => (
      <li class="topo-row">
        <span class="topo-step">{String(i + 1).padStart(2, "0")}</span>
        {l.href ? (
          <a class="topo-cap" href={l.href} set:html={l.cap} />
        ) : (
          <span class="topo-cap" set:html={l.cap} />
        )}
        <span class="topo-body" set:html={l.body} />
      </li>
    ))}
  </ol>
</Section>

<Section id="surfaces" title={s.surfaces.title}>
  <table class="why">
    <tbody>
      {s.surfaces.rows.map((r) => (
        <tr>
          <td class="cap" set:html={r.cap} />
          <td set:html={r.body} />
        </tr>
      ))}
    </tbody>
  </table>
</Section>

<Section id="matrix" title={s.matrix.title}>
  <p class="block" set:html={s.matrix.caption} />
  <div class="matrix-wrap">
    <table class="matrix">
      <thead>
        <tr>
          {s.matrix.head.map((h) => (
            <th>{h}</th>
          ))}
        </tr>
      </thead>
      <tbody>
        {s.matrix.rows.map((row) => (
          <tr>
            {row.map((cell, idx) => (
              <td class={idx === 0 ? "m-key" : ""} set:html={cell} />
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <p class="note" set:html={s.matrix.note} />
</Section>

<Section id="status" title={s.status.title}>
  <table class="why">
    <tbody>
      {s.status.rows.map((r) => (
        <tr>
          <td class="cap" set:html={r.cap} />
          <td set:html={r.body} />
        </tr>
      ))}
    </tbody>
  </table>
</Section>

<Section id="bench" title={s.bench.title}>
  <p class="block" set:html={s.bench.caption} />
  <div class="bench-grid">
    {s.bench.rows.map((r) => (
      <article class="bench-card">
        <header class="bench-card-meta">
          <span class="bench-card-date">{r.date}</span>
          <span class="bench-card-sep" aria-hidden="true">·</span>
          <code class="bench-card-backend">{r.backend}</code>
          <span class="bench-card-sep" aria-hidden="true">·</span>
          <span class="bench-card-model">{r.model}</span>
          <span class="bench-card-sep" aria-hidden="true">·</span>
          <span class="bench-card-hw">{r.hardware}</span>
        </header>
        <p class="bench-card-metric" set:html={r.metric} />
        <a class="bench-card-link" href={r.href}>full snapshot &#x2197;</a>
      </article>
    ))}
  </div>
  <p class="note" set:html={s.bench.note} />
</Section>

<Section id="quickstart" title={s.quickstart.title}>
  <div class="quickgrid">
    {s.quickstart.cards.map((c) => (
      <article class="mini-card quick-card">
        <h3 set:html={`&mdash; ${c.title.replace(/^—\s*/, "")}`} />
        <Cmd lines={c.lines} />
      </article>
    ))}
  </div>
  <p class="note" set:html={s.quickstart.note} />
</Section>

<Section id="synopsis" title={s.synopsis.title}>
  <Cmd lines={s.synopsis.lines} lined={true} />
</Section>

<Section id="examples" title={s.examples.title}>
  <p class="block" set:html={s.examples.lead} />
  <Cmd lines={s.examples.lines} lined={true} />
  <p class="note" set:html={s.examples.seeAlso} />
</Section>

<Section id="docs" title={s.files.title}>
  <ul class="files-list">
    {s.files.rows.map((r) => (
      <li>
        <a class="files-path" href={r.href}>{r.path}</a>
        <span class="files-leader" aria-hidden="true"></span>
        <span class="files-desc" set:html={r.desc} />
      </li>
    ))}
  </ul>
</Section>

<Section id="see-also" title={s.seealso.title}>
  <ul class="seealso">
    {s.seealso.items.map((it) => (
      <li set:html={it} />
    ))}
  </ul>
  <p class="note" set:html={s.seealso.note} />
</Section>

<DocFooter cols={locale.docfoot.cols} meta={locale.docfoot.meta} />
