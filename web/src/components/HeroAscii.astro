---
interface Props {
  ariaLabel: string;
}
const { ariaLabel } = Astro.props;
---
<div class="wordmark" aria-label={ariaLabel}>
  <svg class="wordmark-mark" viewBox="10 18 60 72" aria-hidden="true">
    <path d="M 57 35 A 24 24 0 1 0 57 77" fill="none" stroke="currentColor" stroke-width="16" stroke-linecap="butt"/>
    <rect x="53" y="20" width="16" height="68" fill="currentColor"/>
    <polygon points="26,46 26,62 44,54" fill="var(--coral)"/>
  </svg><span class="wordmark-name">rle</span>
</div>
