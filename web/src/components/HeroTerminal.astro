---
import type { DemoLine } from "../data/content.ts";
interface Props {
  kicker: string;
  label: string;
  lines: DemoLine[];
}
const { kicker, label, lines } = Astro.props;

// Render the line stream as a single HTML string so JSX whitespace doesn't
// leak into the visible output of the terminal demo.
const lineHtml = lines
  .map((line, i) => {
    const cursor = i === lines.length - 1
      ? '<span class="demo-cursor" aria-hidden="true"></span>'
      : "";
    return `<span class="demo-line type-${i + 1}">${line.html}${cursor}</span>`;
  })
  .join("");
---
<aside class="hero-demo" aria-label="terminal demo">
  <p class="hero-demo-kicker">
    <span class="lbl-l">{kicker}</span>
    <span class="lbl-r">{label}</span>
  </p>
  <div class="hero-demo-stream" set:html={lineHtml}></div>
</aside>
