---
import type { TopNavLink } from "../data/content.ts";

interface Props {
  left: string;
  links: TopNavLink[];
}
const { left, links } = Astro.props;
---
<header class="masthead">
  <span class="left">{left}</span>
  <nav class="right" aria-label="primary">
    {links.map((l) => <a href={l.href}>{l.label}</a>)}
  </nav>
</header>
<style>
  .masthead {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 24px;
    border-bottom: 1px solid var(--line);
    padding-bottom: 14px;
    margin-bottom: 88px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-dim);
  }
  .left {
    color: var(--ink);
    font-weight: 700;
    flex: none;
  }
  .right {
    display: flex;
    gap: 22px;
    flex-wrap: nowrap;
    flex: none;
    white-space: nowrap;
  }
  .right a {
    color: inherit;
    text-decoration: none;
    transition: color var(--t-base);
  }
  .right a:hover { color: var(--ink); }
</style>
