---
interface Props {
  primaryHref: string;
  primaryLabel: string;
  secondaryHref: string;
  secondaryLabel: string;
  ariaLabel?: string;
}
const {
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel,
  ariaLabel = "primary actions",
} = Astro.props;
---
<div class="hero-cta" aria-label={ariaLabel}>
  <a class="hero-cta-primary" href={primaryHref}>
    <span class="p">$</span> {primaryLabel}
  </a>
  <a class="hero-cta-secondary" href={secondaryHref}>
    {secondaryLabel} <span class="arrow" aria-hidden="true">&#x2197;</span>
  </a>
</div>
