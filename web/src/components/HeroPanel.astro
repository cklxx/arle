---
interface Props {
  kicker: string;
  title: string;       // raw HTML
  rows: { k: string; v: string }[]; // v allows raw HTML
  note: string;        // raw HTML
}
const { kicker, title, rows, note } = Astro.props;
---
<aside class="hero-meta-callout" aria-label="project summary">
  <div class="meta-shell">
    <div>
      <p class="panel-kicker">{kicker}</p>
      <p class="panel-title" set:html={title} />
      <p class="panel-note" set:html={note} />
    </div>
    <table class="hero-meta">
      <tbody>
        {rows.map((r) => (
          <tr>
            <td>{r.k}</td>
            <td set:html={r.v} />
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</aside>
