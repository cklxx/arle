# agent-infer example environment configuration
#
# Copy values from here into your shell or local env file as needed.
# This file is documentation-oriented; not every variable is needed for every
# workflow.

# --- CLI runtime ---
AGENT_INFER_MODEL=models/Qwen3-4B

# --- CUDA build ---
CUDA_HOME=/usr/local/cuda
PEGAINFER_TRITON_PYTHON=.venv/bin/python

# Optional explicit SM override when GPU auto-detection is unavailable
# PEGAINFER_CUDA_SM=80,90

# --- GPU tests ---
PEGAINFER_TEST_MODEL_PATH=models/Qwen3-4B

# --- Integration API tests ---
# PEGAINFER_URL=http://localhost:8000
# PEGAINFER_MODEL=Qwen3-8B

# --- setup.sh ---
# MODEL_ID=Qwen/Qwen3-8B
# MODEL_DIR=models/Qwen3-8B
# SKIP_MODEL=1
# PYTHON=python3
